# Manufacturing Domain-Specialized FastAPI Agent environment example
# Copy to .env and fill in your OpenAI key.

APP_ENV=local
AI_SERVER_PORT=8000

# Paths. By default, the app resolves these paths automatically:
# DATA_DIR=<project_root>/data
# STORAGE_DIR=<project_root>/ai_server/storage
# DOMAIN_DIR=<project_root>/ai_server/domain
# DATA_DIR=/absolute/path/to/data
# STORAGE_DIR=/absolute/path/to/storage
# DOMAIN_DIR=/absolute/path/to/domain

# LLM provider options:
# - openai: official OpenAI Responses API
# - openai_compatible: OpenAI-compatible Chat Completions JSON mode
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.4-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=

# LangSmith tracing for notebook-based RAG evaluation. Do not commit real keys.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=manufacturing-agent-eval

# KOSHA public data API. Do not commit real keys.
KOSHA_API_KEY=
KOSHA_CALL_API_ID=1050

# RAG vector DB / embedding pipeline
RAG_EMBEDDING_PROVIDER=openai
RAG_EMBEDDING_MODEL=text-embedding-3-small
CHROMA_COLLECTION=manufacturing_rag
CHROMA_PERSIST_DIR=ai_server/data/vector_db/chroma

LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=60
LLM_MAX_OUTPUT_TOKENS=1800
LLM_ENABLE_STRUCTURED_OUTPUT=true
LLM_ALLOW_EXPENSIVE_MODELS=false
USD_KRW_EXCHANGE_RATE=1400

# Agent runtime controls
AGENT_SUPERVISOR_LLM_REFINEMENT=true
AGENT_MAX_RAG_TOP_K=8
AGENT_MAX_REPLAN_ATTEMPTS=2
RAG_MIN_NORMALIZED_SCORE=0.05
MAX_CONTEXT_TOKENS=2000
MAX_RECENT_RUNS=3
MAX_SIMILAR_RUNS=3
MAX_LONG_TERM_MEMORIES=5

# API security. Keep false for local-only testing; set true before exposing the API.
API_AUTH_ENABLED=false
API_KEY=change-me
CORS_ALLOW_ORIGINS=http://localhost:8501,http://127.0.0.1:8501,http://localhost:3000,http://127.0.0.1:3000

# History store
# HISTORY_DB_PATH=<project_root>/ai_server/storage/history/agent_runs.sqlite3
